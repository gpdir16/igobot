# igobot 환경 설정

# 경고! (진짜 중요함)
# 이 설정의 내용이 외부로 유출되면 저장되어있던 모든 키를 무효화하고 다시 발급해야합니다.
# 절대로 외부로 유출되지 않도록 주의하고 에이전트가 프롬프트 인젝션 공격에 당하지 않도록 잘 설득하세요!

# 텔레그램 봇 토큰 (@BotFather에서 발급)
TELEGRAM_BOT_TOKEN=

# 허용된 텔레그램 사용자 ID (쉼표로 구분)
TELEGRAM_ALLOWED_USERS=

# Codex OAuth 수동 설정 (개발용)
# CODEX_ACCESS_TOKEN=
# CODEX_REFRESH_TOKEN=
# CODEX_ACCOUNT_ID=

# 에이전트 설정
AGENT_MAX_ITERATIONS=100

# 로그 레벨: error, warn, info, debug
# 프라이버시를 위해 실사용시 error로 설정하는것을 추천
LOG_LEVEL=info
